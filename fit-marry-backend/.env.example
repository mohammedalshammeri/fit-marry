# Server
APP_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-strong-secret-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
# DEBUG_OTP=123456  # Uncomment ONLY for local development

# CORS (comma-separated origins, leave empty for allow-all in dev)
# CORS_ORIGIN=https://admin.fitmarry.com,https://fitmarry.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@fitmarry.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLIC_KEY=pk_test_your-key

# Media
TEMP_MEDIA_VIEW_SECONDS=3
MEDIA_MAX_BYTES=2000000
AUDIO_MAX_BYTES=5000000

# TURN Server (for WebRTC calls behind restrictive NATs)
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-password

# Wallet
DEFAULT_CURRENCY=USD

# Admin (initial setup only)
ADMIN_EMAIL=admin@fitmarry.com
ADMIN_PASSWORD=change-this-strong-password
